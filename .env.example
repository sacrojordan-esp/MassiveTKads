# TikTok Ads - Configuración del proyecto
# Copiá este archivo como .env y completá con tus valores reales
# cp .env.example .env

CARPETA_COOKIES=cuentas
CORRECCION_FILE=correccion.json
UMBRAL_DIAS=5

# Mapa de cuentas TikTok Ads: "Nombre Cuenta" -> "AADVID"
# Formato JSON: {"Nombre": "ID", "Nombre2": "ID2"}
CUENTAS_AADVID={"Tu Cuenta": "TU_AADVID"}

# Cookies importantes para el monitoreo de expiración
COOKIES_IMPORTANTES={"sessionid": "Sesión principal", "sessionid_ads": "Sesión de anuncios", "sid_tt": "SID TikTok", "sid_tt_ads": "SID anuncios", "csrftoken": "CSRF token", "msToken": "Token móvil", "ttwid": "Token web", "sid_guard": "SID guard", "sid_guard_ads": "SID guard ads"}
